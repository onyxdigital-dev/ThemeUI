<?php
$cfg_path         = "/boot/config/plugins/themeui/themeui.cfg";
$override_path    = "/boot/config/plugins/themeui/custom-override.css";
$webroot_override = "/usr/local/emhttp/plugins/ThemeUI/custom-override.css";
$msg = "";

require_once "$docroot/plugins/dynamix/include/Wrappers.php";

$valid_themes  = ["default","catppuccin-mocha","nord","dracula","gruvbox-dark","tokyo-night","solarized-dark","one-dark","rose-pine","everforest","black-white"];
$valid_designs = ["default","modern"];

$theme_meta = [
    "default"          => ["label"=>"Default (Unraid)",  "colors"=>["#1c1b22","#f0f0f0","#ff8c00","#cc0000","#4a4a5a"]],
    "catppuccin-mocha" => ["label"=>"Catppuccin Mocha",  "colors"=>["#1e1e2e","#cdd6f4","#fab387","#f38ba8","#89b4fa"]],
    "nord"             => ["label"=>"Nord",               "colors"=>["#2e3440","#eceff4","#d08770","#bf616a","#88c0d0"]],
    "dracula"          => ["label"=>"Dracula",            "colors"=>["#282a36","#f8f8f2","#ffb86c","#ff5555","#bd93f9"]],
    "gruvbox-dark"     => ["label"=>"Gruvbox Dark",       "colors"=>["#282828","#ebdbb2","#fe8019","#fb4934","#83a598"]],
    "tokyo-night"      => ["label"=>"Tokyo Night",        "colors"=>["#1a1b26","#c0caf5","#ff9e64","#f7768e","#7aa2f7"]],
    "solarized-dark"   => ["label"=>"Solarized Dark",     "colors"=>["#002b36","#839496","#cb4b16","#dc322f","#268bd2"]],
    "one-dark"         => ["label"=>"One Dark",           "colors"=>["#282c34","#abb2bf","#d19a66","#e06c75","#61afef"]],
    "rose-pine"        => ["label"=>"Rose Pine",          "colors"=>["#191724","#e0def4","#f6c177","#eb6f92","#c4a7e7"]],
    "everforest"       => ["label"=>"Everforest",         "colors"=>["#2d353b","#d3c6aa","#e69875","#e67e80","#a7c080"]],
    "black-white"      => ["label"=>"Black and White",    "colors"=>["#0d0d0d","#e8e8e8","#cccccc","#aaaaaa","#888888"]],
];

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (isset($_POST['SAVE_CONFIG'])) {
        $service = (isset($_POST['SERVICE']) && $_POST['SERVICE'] === 'enabled') ? 'enabled' : 'disabled';
        $theme   = in_array($_POST['THEME']  ?? '', $valid_themes)  ? $_POST['THEME']  : 'default';
        $design  = in_array($_POST['DESIGN'] ?? '', $valid_designs) ? $_POST['DESIGN'] : 'default';
        file_put_contents($cfg_path, "SERVICE=\"$service\"\nTHEME=\"$theme\"\nDESIGN=\"$design\"\n");
        if (isset($_POST['custom_css'])) {
            file_put_contents($override_path, $_POST['custom_css']);
            @copy($override_path, $webroot_override);
        }
        $login_page = "/usr/local/emhttp/webGui/include/.login.php";
        if (file_exists($login_page)) {
            $plug = "/usr/local/emhttp/plugins/ThemeUI";
            $html = file_get_contents($login_page);
            $html = preg_replace('/<!--themeui-start-->.*?<!--themeui-end-->\n?/s', '', $html);
            if ($service === 'enabled' && $theme !== 'default') {
                $css  = @file_get_contents("$plug/themes/$theme.css") ?: '';
                $css .= "\n" . (@file_get_contents("$plug/themes/login.css") ?: '');
                $block = "<!--themeui-start-->\n<style>\n$css\n</style>\n<!--themeui-end-->";
                $html = str_replace('</head>', "$block\n</head>", $html);
            }
            file_put_contents($login_page, $html);
            if (function_exists('opcache_reset')) {
                opcache_reset();
            } elseif (function_exists('opcache_invalidate')) {
                opcache_invalidate($login_page, true);
            }
        }
        $msg = "Settings saved - applying theme...";
    }
}

if (!file_exists($cfg_path)) {
    file_put_contents($cfg_path, "SERVICE=\"disabled\"\nTHEME=\"default\"\n");
}
if (!file_exists($override_path)) {
    file_put_contents($override_path, "/* Custom CSS overrides - applied on top of the selected theme */\n");
    @copy($override_path, $webroot_override);
}

$settings   = parse_plugin_cfg("themeui");
$service    = $settings['SERVICE'] ?? 'disabled';
$theme      = $settings['THEME']   ?? 'default';
$design     = $settings['DESIGN']  ?? 'default';
$custom_css = file_get_contents($override_path);
?>

<?php if ($msg): ?>
<div style="margin-bottom:20px">
  <span style="color:#a6e3a1;font-weight:500"><?= htmlspecialchars($msg) ?></span>
</div>
<script>setTimeout(function(){ location.href=location.pathname; }, 800);</script>
<?php endif; ?>

<style>
.tui{display:flex;gap:28px;align-items:flex-start;max-width:1100px}
.tui-left{flex:1;min-width:0}
.tui-right{width:280px;flex-shrink:0;position:sticky;top:20px}
.tui-section{margin-bottom:32px}
.tui-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--alt-text-color,#888);margin-bottom:12px}
.tui-switch{position:relative;display:inline-block;width:46px;height:26px;cursor:pointer;flex-shrink:0}
.tui-switch input{opacity:0;width:0;height:0;position:absolute}
.tui-knob{position:absolute;inset:0;background:var(--border-color,#444);border-radius:13px;transition:background .2s}
.tui-knob::after{content:'';position:absolute;width:20px;height:20px;background:#fff;border-radius:50%;top:3px;left:3px;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.3)}
.tui-switch input:checked+.tui-knob{background:var(--usage-bar-used-background-color,#89b4fa)}
.tui-switch input:checked+.tui-knob::after{transform:translateX(20px)}
.tui-toggle-row{display:flex;align-items:center;gap:12px}
.tui-status{font-size:13px;color:var(--text-color,#cdd6f4)}
.tui-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px}
.tui-card{display:flex;flex-direction:column;gap:9px;padding:12px 14px;background:var(--mild-background-color,#181825);border:2px solid var(--border-color,#313244);border-radius:10px;cursor:pointer;transition:border-color .15s,transform .1s;user-select:none}
.tui-card input{display:none}
.tui-card:hover{border-color:var(--input-border-color,#6c7086);transform:translateY(-1px)}
.tui-card.sel{border-color:var(--usage-bar-used-background-color,#89b4fa)}
.tui-card-name{font-size:12px;font-weight:500;color:var(--text-color,#cdd6f4);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tui-dots{display:flex;gap:4px}
.tui-dots span{width:16px;height:16px;border-radius:4px;border:1px solid rgba(128,128,128,.2);flex-shrink:0}
.tui-pills{display:flex;gap:8px}
.tui-pill{padding:7px 22px;border:2px solid var(--border-color,#313244);border-radius:20px;cursor:pointer;font-size:13px;color:var(--text-color,#cdd6f4);transition:border-color .15s,color .15s;user-select:none}
.tui-pill input{display:none}
.tui-pill:hover{border-color:var(--input-border-color,#6c7086)}
.tui-pill.sel{border-color:var(--usage-bar-used-background-color,#89b4fa);color:var(--usage-bar-used-background-color,#89b4fa)}
.tui-hint{margin-top:8px;font-size:12px;color:var(--alt-text-color,#888)}
.tui-hint a{color:var(--usage-bar-used-background-color,#89b4fa);text-decoration:none}
.tui-hint a:hover{text-decoration:underline}
.tui-textarea{display:block;width:100%;height:420px;font-family:monospace;font-size:12px;background:var(--mild-background-color,#181825);color:var(--text-color,#cdd6f4);border:1px solid var(--input-border-color,#6c7086);border-radius:8px;padding:10px 12px;box-sizing:border-box;resize:vertical;outline:none;transition:border-color .15s}
.tui-textarea:focus{border-color:var(--usage-bar-used-background-color,#89b4fa)}
.tui-actions{display:flex;gap:10px;padding-top:4px}
</style>

<form method="POST" action="/Settings/ThemeUI">
<div class="tui">

  <div class="tui-left">
    <div class="tui-section">
      <div class="tui-label">Enable ThemeUI</div>
      <div class="tui-toggle-row">
        <label class="tui-switch">
          <input type="checkbox" name="SERVICE" value="enabled" id="tui-enable"
            <?= $service === 'enabled' ? 'checked' : '' ?>
            onchange="document.getElementById('tui-status').textContent=this.checked?'Enabled':'Disabled';tuiDirty()">
          <span class="tui-knob"></span>
        </label>
        <span class="tui-status" id="tui-status"><?= $service === 'enabled' ? 'Enabled' : 'Disabled' ?></span>
      </div>
    </div>

    <div class="tui-section">
      <div class="tui-label">Theme</div>
      <div class="tui-grid">
        <?php foreach ($theme_meta as $key => $meta): ?>
        <label class="tui-card<?= $theme === $key ? ' sel' : '' ?>">
          <input type="radio" name="THEME" value="<?= $key ?>"
            <?= $theme === $key ? 'checked' : '' ?>
            onchange="document.querySelectorAll('.tui-card').forEach(function(c){c.classList.remove('sel')});this.closest('.tui-card').classList.add('sel');tuiDirty()">
          <div class="tui-card-name"><?= htmlspecialchars($meta['label']) ?></div>
          <div class="tui-dots">
            <?php foreach ($meta['colors'] as $c): ?>
            <span style="background:<?= $c ?>"></span>
            <?php endforeach; ?>
          </div>
        </label>
        <?php endforeach; ?>
      </div>
    </div>

    <div class="tui-section">
      <div class="tui-label">Design Style</div>
      <div class="tui-pills">
        <label class="tui-pill<?= $design === 'default' ? ' sel' : '' ?>">
          <input type="radio" name="DESIGN" value="default"
            <?= $design === 'default' ? 'checked' : '' ?>
            onchange="document.querySelectorAll('.tui-pill').forEach(function(p){p.classList.remove('sel')});this.closest('.tui-pill').classList.add('sel');tuiDirty()">
          Default
        </label>
        <label class="tui-pill<?= $design === 'modern' ? ' sel' : '' ?>">
          <input type="radio" name="DESIGN" value="modern"
            <?= $design === 'modern' ? 'checked' : '' ?>
            onchange="document.querySelectorAll('.tui-pill').forEach(function(p){p.classList.remove('sel')});this.closest('.tui-pill').classList.add('sel');tuiDirty()">
          Modern
        </label>
      </div>
      <div class="tui-hint">Modern adds rounded corners and smooth transitions to all UI elements.</div>
    </div>

    <div class="tui-actions">
      <input type="submit" name="SAVE_CONFIG" value="Apply" id="tui-apply" disabled>
      <input type="button" value="Done" onclick="done()">
    </div>
  </div>

  <div class="tui-right">
    <div class="tui-section">
      <div class="tui-label">Custom CSS Override</div>
      <textarea name="custom_css" class="tui-textarea" spellcheck="false" oninput="tuiDirty()"><?= htmlspecialchars($custom_css) ?></textarea>
      <div class="tui-hint">Injected after the active theme. Reference: <a href="/webGui/styles/themes/white.css" target="_blank">white.css</a> &nbsp;|&nbsp; <a href="/webGui/styles/themes/black.css" target="_blank">black.css</a></div>
    </div>
  </div>

</div>
</form>

<script>
function tuiDirty(){ document.getElementById('tui-apply').removeAttribute('disabled'); }
</script>
